[0.1, "o", "CoherentVolume \u2014 sequential stale-overwrite (lost-update) demo.\r\n"]
[0.332, "o", "Same read\u2192write sequence both times; only the coordination differs.\r\n"]
[0.567, "o", "\r\n"]
[0.831, "o", "BROKEN (no coherence) \u2014 sequential stale-overwrite over plain files\r\n"]
[1.543, "o", "  scenario: two agents update a shared total (start=100; A adds 10, B adds 5)\r\n"]
[1.776, "o", "  A wrote 110, then B wrote 105 (from its older read)\r\n"]
[2.007, "o", "  LOST UPDATE: True  (final=105, expected=115)\r\n"]
[3.826, "o", "\r\n"]
[4.09, "o", "FIXED (CoherentVolume) \u2014 the stale write is denied, then recovered\r\n"]
[4.8, "o", "  scenario: two agents update a shared total (start=100; A adds 10, B adds 5)\r\n"]
[5.03, "o", "  B's stale write denied: True  (fail-closed)\r\n"]
[5.26, "o", "  B recovered via reacquire(): True\r\n"]
[5.49, "o", "  LOST UPDATE: False  (final=115, expected=115)\r\n"]
[7.099, "o", "\r\n"]
[7.362, "o", "Takeaway: without coherence, B's write from an older read silently\r\n"]
[7.978, "o", "overwrites A (lost update). CoherentVolume denies that write fail-closed,\r\n"]
[8.209, "o", "B reacquires the current value and rewrites \u2014 both updates survive.\r\n"]
